dataset_path: yale-nlp/TOMATO
dataset_kwargs:
  token: True
  video: True
  cache_dir: tomato_video
generation_kwargs:
  max_new_tokens: 16
  temperature: 0
  top_p: 1.0
  num_beams: 1
  do_sample: false

output_type: generate_until
doc_to_visual: !function utils.tomato_doc_to_visual
doc_to_text: !function utils.tomato_doc_to_text
doc_to_target: !function utils.tomato_doc_to_answer
# The return value of process_results will be used by metrics
process_results: !function utils.tomato_process_results
# Note that the metric name can be either a registered metric function or a key name returned by process_results
metric_list:
  - metric: tomato_accuracy
    aggregation: !function utils.tomato_aggregate_results
    higher_is_better: true

lmms_eval_specific_kwargs:
  default:
    post_prompt: "Only give the best option.\n"
